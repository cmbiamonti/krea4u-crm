# =============================================================================
# KREA4U CRM — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your own values.
#
#   cp .env.example .env
#
# ⚠️  IMPORTANT:
#   - Never commit the .env file to version control
#   - The .env file is listed in .gitignore — keep it that way
#   - This .env.example file contains NO real credentials
# =============================================================================


# -----------------------------------------------------------------------------
# SUPABASE
# Get these from: https://supabase.com → Project Settings → API
# -----------------------------------------------------------------------------

# Your Supabase project URL (format: https://xxxxxxxxxxxx.supabase.co)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Public Anon Key — safe to expose in frontend code.
# Security is enforced by Row Level Security (RLS) policies in the database.
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Service Role Key — SERVER-SIDE ONLY. NEVER use in frontend code.
# Use only in Supabase Edge Functions or a secure backend.
# Get from: Project Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here


# -----------------------------------------------------------------------------
# GOOGLE MAPS
# Get your API key from: https://console.cloud.google.com
# Enable: Maps JavaScript API
# Restrict the key to your domain for security.
# -----------------------------------------------------------------------------

VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here


# -----------------------------------------------------------------------------
# EMAIL — SMTP Configuration
# Used for sending newsletters and transactional emails.
# These values are SERVER-SIDE ONLY (Supabase Edge Functions or backend).
# Never expose SMTP credentials in frontend code.
#
# Hostinger example values are shown — replace with your actual provider.
# -----------------------------------------------------------------------------

# SMTP server hostname
# Hostinger: smtp.hostinger.com
SMTP_HOST=smtp.hostinger.com

# SMTP port
# 465 = SSL (recommended) | 587 = TLS/STARTTLS
SMTP_PORT=465

# SMTP encryption: ssl | tls
SMTP_SECURE=ssl

# Your email address used to authenticate with the SMTP server
SMTP_USER=your-email@yourdomain.com

# SMTP password — keep this secret
SMTP_PASSWORD=your-smtp-password-here

# Sender display name shown in the recipient's inbox
SMTP_FROM_NAME=Krea4U CRM

# Reply-to address (can be the same as SMTP_USER or a different address)
SMTP_REPLY_TO=your-email@yourdomain.com


# -----------------------------------------------------------------------------
# GOOGLE ANALYTICS (optional)
# Set up a GA4 property at: https://analytics.google.com
# Leave blank or remove this line to disable analytics entirely.
# Format: G-XXXXXXXXXX
# -----------------------------------------------------------------------------

VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX


# -----------------------------------------------------------------------------
# APP SETTINGS (optional)
# -----------------------------------------------------------------------------

# Application name displayed in the UI and browser tab
VITE_APP_NAME=Krea4U CRM

# Base URL of your deployed app (used for links in emails, etc.)
# Example: https://crm.yourdomain.com
VITE_APP_URL=http://localhost:5173

# Default locale for date/number formatting
VITE_DEFAULT_LOCALE=it-IT
